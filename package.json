{
  "name": "aria-lab-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Aria Lab - React Aria component library monorepo",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm --filter aria-lab build",
    "dev": "pnpm --filter aria-lab dev",
    "dev:showcase": "pnpm --filter showcase dev",
    "storybook": "pnpm --filter storybook storybook",
    "build-storybook": "pnpm --filter storybook build-storybook",
    "build:showcase": "pnpm --filter showcase build",
    "build:analyze": "pnpm --filter showcase build:analyze",
    "test": "pnpm --filter aria-lab test",
    "typecheck": "pnpm --filter aria-lab typecheck",
    "lint": "pnpm -r lint",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm build:showcase"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
