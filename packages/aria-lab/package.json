{
  "name": "aria-lab",
  "version": "0.1.0-beta.2",
  "description": "React Aria component library with full accessibility",
  "homepage": "https://github.com/timurmaio/aria-lab#readme",
  "bugs": {
    "url": "https://github.com/timurmaio/aria-lab/issues"
  },
  "license": "MIT",
  "author": "Timur Makarov <timurmaio@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timurmaio/aria-lab.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./theme": "./dist/theme/index.css",
    "./theme/index.css": "./dist/theme/index.css",
    "./theme/tokens": "./dist/theme/tokens.css",
    "./theme/tokens.css": "./dist/theme/tokens.css",
    "./theme/default": "./dist/theme/default.css",
    "./theme/default.css": "./dist/theme/default.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack --copy src/theme && vp run build:styles",
    "build:styles": "vp exec tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "vp exec bumpp && vp pm publish",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "lucide-react": "1.21.0",
    "react-aria": "3.50.0",
    "react-aria-components": "1.19.0",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.15.17",
    "@types/react": "19.1.3",
    "@types/react-dom": "19.1.4",
    "@vitest/coverage-v8": "4.1.0",
    "happy-dom": "17.6.3",
    "jsdom": "26.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "tailwindcss": "4.2.2",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-react-aria-components": "2.2.0",
    "typescript": "5.9.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-aria-components": ">=1.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "react-aria-components": {
      "optional": false
    }
  }
}
